# LLM Backend Tokens
# Non-sensitive config (URLs, models, timeouts) is defined in test/llm-profiles.ts
# Only tokens need to be set as environment variables.

# Optional: override which LLM profile demos use (default: bigmodel)
# Valid values: local, bigmodel, jereh
# LLM_PROFILE=bigmodel

# Local Jereh LLM (http://10.1.3.115:4000)
ANTHROPIC_AUTH_TOKEN_LOCAL=your_local_token_here

# BigModel / GLM (https://open.bigmodel.cn/api/anthropic)
ANTHROPIC_AUTH_TOKEN_BIGMODEL=your_bigmodel_token_here

# Jereh Proxy (http://aiproxy.jereh.cn:4000)
ANTHROPIC_AUTH_TOKEN_JEREH=your_jereh_token_here
