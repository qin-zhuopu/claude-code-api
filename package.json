{
  "name": "claude-code-api",
  "version": "1.0.0",
  "description": "REST API for Claude Agent SDK",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "vitest --run",
    "test:integration": "vitest --config ./test/integration/vitest.config.ts --run",
    "test:integration:watch": "vitest --config ./test/integration/vitest.config.ts",
    "demo": "echo '\\n📋 Available demos:\\n  npm run demo:simple-query       - Simple query demo\\n  npm run demo:memory            - Conversation memory demo\\n  npm run demo:stream           - Real-time streaming demo (需先启动服务器)\\n  npm run demo:claude-code-intro - Claude Code introduction (1000+ words, no tools)\\n'",
    "demo:simple-query": "vitest --config ./test/demos/vitest.simple-query.config.ts --run",
    "demo:memory": "vitest --config ./test/demos/vitest.memory.config.ts --run",
    "demo:stream": "node test/demos/stream-demo-simple.mjs",
    "demo:claude-code-intro": "vitest --config ./test/demos/vitest.claude-code-intro.config.ts --run"
  },
  "keywords": [
    "claude",
    "anthropic",
    "sdk",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.133",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.1",
    "@types/node": "^25.6.2",
    "@types/supertest": "^7.2.0",
    "@vitest/ui": "^4.1.5",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
